{
  "manifest_version": 2,
  "name": "TabMark-Bookmark New Tab",
  "version": "1.246",
  "description": "__MSG_extDescription__",
  "default_locale": "zh_CN",
  "chrome_url_overrides": {
    "newtab": "src/index.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabmark@example.com",
      "strict_min_version": "60.0",
      "data_collection_permissions": {
        "required": [
          "bookmarksInfo",
          "browsingActivity"
        ],
        "optional": []
      }
    }
  },
  "permissions": [
    "bookmarks",
    "storage",
    "history",
    "tabs",
    "<all_urls>"
  ],
  "browser_action": {
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "background": {
    "scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/sidepanel-navigation.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    "_favicon/*",
    "src/fonts/*",
    "images/sider-icon/*",
    "images/*"
  ],
  "sidebar_action": {
    "default_panel": "src/sidepanel.html",
    "default_icon": "images/icon-48.png",
    "default_title": "TabMark Bookmarks",
    "open_at_install": false
  },
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Alt+B",
        "mac": "Command+B"
      },
      "description": "打开侧边栏"
    }
  }
}
